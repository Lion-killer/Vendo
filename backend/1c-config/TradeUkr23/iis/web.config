<?xml version="1.0" encoding="UTF-8"?>
<!-- ASCII ONLY. This file is declared UTF-8. A Cyrillic comment saved as ANSI/1251
     (Notepad default) produces invalid UTF-8 bytes: IIS then fails the whole
     publication with HTTP 500.19 / 0x8007000d, web client included.
     A double hyphen inside a comment is illegal in XML for the same reason. -->
<configuration>
    <system.webServer>
        <handlers>
            <!-- Generated by Configurator. The path differs per platform build and
                 vendor folder (1cv8, BAF, ...). Copy it, do not retype it. -->
            <add name="1C Web-service Extension"
                 path="*"
                 verb="*"
                 modules="IsapiModule"
                 scriptProcessor="C:\Program Files (x86)\1cv8\8.3.19.1529\bin\wsisapi.dll"
                 resourceType="Unspecified"
                 requireAccess="None" />
        </handlers>

        <!-- REQUIRED. Lets the service's own JSON error bodies reach the client.
             Without it IIS replaces every 4xx/5xx body with its HTML error page. -->
        <httpErrors existingResponse="PassThrough" />
    </system.webServer>
</configuration>
