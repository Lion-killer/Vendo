<?xml version="1.0" encoding="UTF-8"?>
<Form xmlns="http://v8.1c.ru/8.3/xcf/logform" xmlns:app="http://v8.1c.ru/8.2/managed-application/core" xmlns:cfg="http://v8.1c.ru/8.1/data/enterprise/current-config" xmlns:dcscor="http://v8.1c.ru/8.1/data-composition-system/core" xmlns:dcssch="http://v8.1c.ru/8.1/data-composition-system/schema" xmlns:dcsset="http://v8.1c.ru/8.1/data-composition-system/settings" xmlns:ent="http://v8.1c.ru/8.1/data/enterprise" xmlns:lf="http://v8.1c.ru/8.2/managed-application/logform" xmlns:style="http://v8.1c.ru/8.1/data/ui/style" xmlns:sys="http://v8.1c.ru/8.1/data/ui/fonts/system" xmlns:v8="http://v8.1c.ru/8.1/data/core" xmlns:v8ui="http://v8.1c.ru/8.1/data/ui" xmlns:web="http://v8.1c.ru/8.1/data/ui/colors/web" xmlns:win="http://v8.1c.ru/8.1/data/ui/colors/windows" xmlns:xr="http://v8.1c.ru/8.3/xcf/readable" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" version="2.17">
	<Title>
		<v8:item>
			<v8:lang>ru</v8:lang>
			<v8:content>Настройки сервиса (Vendo)</v8:content>
		</v8:item>
		<v8:item>
			<v8:lang>uk</v8:lang>
			<v8:content>Налаштування сервісу (Vendo)</v8:content>
		</v8:item>
		<v8:item>
			<v8:lang>en</v8:lang>
			<v8:content>Service settings (Vendo)</v8:content>
		</v8:item>
	</Title>
	<AutoTitle>false</AutoTitle>
	<WindowOpeningMode>LockOwnerWindow</WindowOpeningMode>
	<AutoCommandBar name="ФормаКоманднаяПанель" id="-1">
		<ChildItems>
			<Button name="ЗаписатьИЗакрыть" id="1">
				<Type>CommandBarButton</Type>
				<CommandName>Form.Command.ЗаписатьИЗакрыть</CommandName>
				<DefaultButton>true</DefaultButton>
				<ExtendedTooltip name="ЗаписатьИЗакрытьРасширеннаяПодсказка" id="2" />
			</Button>
			<Button name="Закрыть" id="3">
				<Type>CommandBarButton</Type>
				<CommandName>Form.StandardCommand.Close</CommandName>
				<ExtendedTooltip name="ЗакрытьРасширеннаяПодсказка" id="4" />
			</Button>
		</ChildItems>
	</AutoCommandBar>
	<Events>
		<Event name="OnCreateAtServer">ПриСозданииНаСервере</Event>
	</Events>
	<ChildItems>
		<InputField name="АдресСервиса" id="5">
			<DataPath>АдресСервиса</DataPath>
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Адрес сервиса (URL)</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>uk</v8:lang>
					<v8:content>Адреса сервісу (URL)</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>Service URL</v8:content>
				</v8:item>
			</Title>
			<ToolTip>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Адрес публикации HTTP-сервиса мобильного приложения. Зашивается в QR-код каждого устройства — пока не задан, QR не рабочий.</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>uk</v8:lang>
					<v8:content>Адреса публікації HTTP-сервісу мобільного застосунку. Зашивається у QR-код кожного пристрою — поки не задана, QR не робочий.</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>Publication URL of the mobile app HTTP service. Embedded into each device QR code — the QR does not work until it is set.</v8:content>
				</v8:item>
			</ToolTip>
			<AutoMaxWidth>false</AutoMaxWidth>
			<HorizontalStretch>true</HorizontalStretch>
			<InputHint>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>http(s)://&lt;сервер&gt;/&lt;база&gt;/hs/vendo</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>uk</v8:lang>
					<v8:content>http(s)://&lt;сервер&gt;/&lt;база&gt;/hs/vendo</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>http(s)://&lt;server&gt;/&lt;base&gt;/hs/vendo</v8:content>
				</v8:item>
			</InputHint>
			<ContextMenu name="АдресСервисаКонтекстноеМеню" id="6" />
			<ExtendedTooltip name="АдресСервисаРасширеннаяПодсказка" id="7" />
		</InputField>
		<InputField name="ХранениеТелеметрииДней" id="8">
			<DataPath>ХранениеТелеметрииДней</DataPath>
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Хранение телеметрии, дней</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>uk</v8:lang>
					<v8:content>Зберігання телеметрії, днів</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>Telemetry retention, days</v8:content>
				</v8:item>
			</Title>
			<ToolTip>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Сколько дней хранить историю телеметрии устройств. Более старые записи удаляются автоматически при поступлении телеметрии (не чаще раза в сутки); последняя запись каждого устройства сохраняется всегда. По умолчанию 30.</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>uk</v8:lang>
					<v8:content>Скільки днів зберігати історію телеметрії пристроїв. Старіші записи видаляються автоматично при надходженні телеметрії (не частіше разу на добу); останній запис кожного пристрою зберігається завжди. Типово 30.</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>How many days to keep device telemetry history. Older records are deleted automatically when telemetry arrives (at most once a day); the latest record of each device is always kept. Default 30.</v8:content>
				</v8:item>
			</ToolTip>
			<ContextMenu name="ХранениеТелеметрииДнейКонтекстноеМеню" id="9" />
			<ExtendedTooltip name="ХранениеТелеметрииДнейРасширеннаяПодсказка" id="10" />
		</InputField>
		<InputField name="ГлубинаИсторииДней" id="11">
			<DataPath>ГлубинаИсторииДней</DataPath>
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Глубина истории заказов, дней</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>uk</v8:lang>
					<v8:content>Глибина історії замовлень, днів</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>Order history depth, days</v8:content>
				</v8:item>
			</Title>
			<ToolTip>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>За сколько дней назад приложение получает заказы, если в карточке устройства глубина не задана. Ограничивает объём и время ответа GET /orders. По умолчанию 30.</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>uk</v8:lang>
					<v8:content>За скільки днів назад застосунок отримує замовлення, якщо в картці пристрою глибину не задано. Обмежує обсяг і час відповіді GET /orders. Типово 30.</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>How many days back the app receives orders when the device card does not set a depth. Caps the size and response time of GET /orders. Default 30.</v8:content>
				</v8:item>
			</ToolTip>
			<ContextMenu name="ГлубинаИсторииДнейКонтекстноеМеню" id="12" />
			<ExtendedTooltip name="ГлубинаИсторииДнейРасширеннаяПодсказка" id="13" />
		</InputField>
		<InputField name="ТротлингАктивностиСек" id="14">
			<DataPath>ТротлингАктивностиСек</DataPath>
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Троттлинг активности, секунд</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>uk</v8:lang>
					<v8:content>Тротлінг активності, секунд</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>Activity throttle, seconds</v8:content>
				</v8:item>
			</Title>
			<ToolTip>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Как часто обновляется «последняя активность» устройства при его запросах (колонка в списке устройств). Меньше — точнее, но больше записей в базу. По умолчанию 300 (5 минут).</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>uk</v8:lang>
					<v8:content>Як часто оновлюється «остання активність» пристрою при його запитах (колонка у списку пристроїв). Менше — точніше, але більше записів у базу. Типово 300 (5 хвилин).</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>How often the device "last activity" is updated on its requests (a column in the device list). Lower is more precise but writes more. Default 300 (5 minutes).</v8:content>
				</v8:item>
			</ToolTip>
			<ContextMenu name="ТротлингАктивностиСекКонтекстноеМеню" id="15" />
			<ExtendedTooltip name="ТротлингАктивностиСекРасширеннаяПодсказка" id="16" />
		</InputField>
		<LabelDecoration name="ПодсказкаУмолчаний" id="17">
			<Title formatted="false">
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>0 в числовом поле — вернуться к значению по умолчанию. Глубину истории перекрывает карточка устройства.</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>uk</v8:lang>
					<v8:content>0 у числовому полі — повернутися до типового значення. Глибину історії перекриває картка пристрою.</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>0 in a numeric field resets to the default. Device card overrides the history depth.</v8:content>
				</v8:item>
			</Title>
			<ContextMenu name="ПодсказкаУмолчанийКонтекстноеМеню" id="18" />
			<ExtendedTooltip name="ПодсказкаУмолчанийРасширеннаяПодсказка" id="19" />
		</LabelDecoration>
		<UsualGroup name="ГруппаИнтервалыПриложения" id="20">
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Интервалы приложения</v8:content>
				</v8:item>
			</Title>
			<Group>Vertical</Group>
			<ExtendedTooltip name="ГруппаИнтервалыПриложенияРасширеннаяПодсказка" id="21" />
			<ChildItems>
				<InputField name="ИнтервалСинхронизацииСек" id="22">
					<DataPath>ИнтервалСинхронизацииСек</DataPath>
					<Title>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Синхронизация данных, секунд</v8:content>
						</v8:item>
					</Title>
					<ContextMenu name="ИнтервалСинхронизацииСекКонтекстноеМеню" id="23" />
					<ExtendedTooltip name="ИнтервалСинхронизацииСекРасширеннаяПодсказка" id="24" />
				</InputField>
				<InputField name="ИнтервалПингаСек" id="25">
					<DataPath>ИнтервалПингаСек</DataPath>
					<Title>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Пинг (онлайн-индикатор), секунд</v8:content>
						</v8:item>
					</Title>
					<ContextMenu name="ИнтервалПингаСекКонтекстноеМеню" id="26" />
					<ExtendedTooltip name="ИнтервалПингаСекРасширеннаяПодсказка" id="27" />
				</InputField>
				<InputField name="ИнтервалТелеметрииСек" id="28">
					<DataPath>ИнтервалТелеметрииСек</DataPath>
					<Title>
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>Телеметрия, секунд</v8:content>
						</v8:item>
					</Title>
					<ContextMenu name="ИнтервалТелеметрииСекКонтекстноеМеню" id="29" />
					<ExtendedTooltip name="ИнтервалТелеметрииСекРасширеннаяПодсказка" id="30" />
				</InputField>
				<LabelDecoration name="ПодсказкаИнтервалов" id="31">
					<Title formatted="false">
						<v8:item>
							<v8:lang>ru</v8:lang>
							<v8:content>0 — цикл отключён. Приложение не имеет собственных значений: циклы работают только с интервалами, полученными из /health.</v8:content>
						</v8:item>
					</Title>
					<ContextMenu name="ПодсказкаИнтерваловКонтекстноеМеню" id="32" />
					<ExtendedTooltip name="ПодсказкаИнтерваловРасширеннаяПодсказка" id="33" />
				</LabelDecoration>
			</ChildItems>
		</UsualGroup>
	</ChildItems>
	<Attributes>
		<Attribute name="АдресСервиса" id="20">
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Адрес сервиса</v8:content>
				</v8:item>
			</Title>
			<Type>
				<v8:Type>xs:string</v8:Type>
				<v8:StringQualifiers>
					<v8:Length>0</v8:Length>
					<v8:AllowedLength>Variable</v8:AllowedLength>
				</v8:StringQualifiers>
			</Type>
		</Attribute>
		<Attribute name="ХранениеТелеметрииДней" id="21">
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Хранение телеметрии дней</v8:content>
				</v8:item>
			</Title>
			<Type>
				<v8:Type>xs:decimal</v8:Type>
				<v8:NumberQualifiers>
					<v8:Digits>5</v8:Digits>
					<v8:FractionDigits>0</v8:FractionDigits>
					<v8:AllowedSign>Nonnegative</v8:AllowedSign>
				</v8:NumberQualifiers>
			</Type>
		</Attribute>
		<Attribute name="ГлубинаИсторииДней" id="22">
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Глубина истории дней</v8:content>
				</v8:item>
			</Title>
			<Type>
				<v8:Type>xs:decimal</v8:Type>
				<v8:NumberQualifiers>
					<v8:Digits>5</v8:Digits>
					<v8:FractionDigits>0</v8:FractionDigits>
					<v8:AllowedSign>Nonnegative</v8:AllowedSign>
				</v8:NumberQualifiers>
			</Type>
		</Attribute>
		<Attribute name="ТротлингАктивностиСек" id="23">
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Тротлинг активности сек</v8:content>
				</v8:item>
			</Title>
			<Type>
				<v8:Type>xs:decimal</v8:Type>
				<v8:NumberQualifiers>
					<v8:Digits>5</v8:Digits>
					<v8:FractionDigits>0</v8:FractionDigits>
					<v8:AllowedSign>Nonnegative</v8:AllowedSign>
				</v8:NumberQualifiers>
			</Type>
		</Attribute>
		<Attribute name="ИнтервалСинхронизацииСек" id="24">
			<Type>
				<v8:Type>xs:decimal</v8:Type>
				<v8:NumberQualifiers>
					<v8:Digits>5</v8:Digits>
					<v8:FractionDigits>0</v8:FractionDigits>
					<v8:AllowedSign>Any</v8:AllowedSign>
				</v8:NumberQualifiers>
			</Type>
		</Attribute>
		<Attribute name="ИнтервалПингаСек" id="25">
			<Type>
				<v8:Type>xs:decimal</v8:Type>
				<v8:NumberQualifiers>
					<v8:Digits>5</v8:Digits>
					<v8:FractionDigits>0</v8:FractionDigits>
					<v8:AllowedSign>Any</v8:AllowedSign>
				</v8:NumberQualifiers>
			</Type>
		</Attribute>
		<Attribute name="ИнтервалТелеметрииСек" id="26">
			<Type>
				<v8:Type>xs:decimal</v8:Type>
				<v8:NumberQualifiers>
					<v8:Digits>5</v8:Digits>
					<v8:FractionDigits>0</v8:FractionDigits>
					<v8:AllowedSign>Any</v8:AllowedSign>
				</v8:NumberQualifiers>
			</Type>
		</Attribute>
	</Attributes>
	<Commands>
		<Command name="ЗаписатьИЗакрыть" id="24">
			<Title>
				<v8:item>
					<v8:lang>ru</v8:lang>
					<v8:content>Записать и закрыть</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>uk</v8:lang>
					<v8:content>Записати й закрити</v8:content>
				</v8:item>
				<v8:item>
					<v8:lang>en</v8:lang>
					<v8:content>Save and close</v8:content>
				</v8:item>
			</Title>
			<Action>ЗаписатьИЗакрыть</Action>
		</Command>
	</Commands>
</Form>
