#Область ОбработчикиСобытийФормы

// Налаштування сервісу (#52): адреса публікації і числові параметри — усе у
// ХранилищеОбщихНастроек (неймспейс "vendo", див. модуль менеджера довідника).
// Числові поля показують ЧИННІ значення (з умолчаннями); 0 = повернутися до умолчання.
// ВИНЯТОК — група «Интервалы приложения» (#68): там 0 означає «цикл вимкнено»,
// бо додаток власних умолчань не має і без значення цикл не запускає.
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	АдресСервиса = Справочники.венд_МобильныеУстройства.АдресСервиса();
	ХранениеТелеметрииДней = Справочники.венд_МобильныеУстройства.ХранениеТелеметрииДней();
	ГлубинаИсторииДней = Справочники.венд_МобильныеУстройства.ГлубинаИсторииДней();
	ТротлингАктивностиСек = Справочники.венд_МобильныеУстройства.ТротлингАктивностиСек();
	ИнтервалСинхронизацииСек = Справочники.венд_МобильныеУстройства.ИнтервалСинхронизацииСек();
	ИнтервалПингаСек = Справочники.венд_МобильныеУстройства.ИнтервалПингаСек();
	ИнтервалТелеметрииСек = Справочники.венд_МобильныеУстройства.ИнтервалТелеметрииСек();

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура ЗаписатьИЗакрыть(Команда)

	ЗаписатьНастройкиНаСервере();
	Закрыть(Истина);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗаписатьНастройкиНаСервере()

	Справочники.венд_МобильныеУстройства.УстановитьАдресСервиса(АдресСервиса);
	Справочники.венд_МобильныеУстройства.УстановитьХранениеТелеметрииДней(ХранениеТелеметрииДней);
	Справочники.венд_МобильныеУстройства.УстановитьГлубинуИсторииДней(ГлубинаИсторииДней);
	Справочники.венд_МобильныеУстройства.УстановитьТротлингАктивностиСек(ТротлингАктивностиСек);
	Справочники.венд_МобильныеУстройства.УстановитьИнтервалСинхронизацииСек(ИнтервалСинхронизацииСек);
	Справочники.венд_МобильныеУстройства.УстановитьИнтервалПингаСек(ИнтервалПингаСек);
	Справочники.венд_МобильныеУстройства.УстановитьИнтервалТелеметрииСек(ИнтервалТелеметрииСек);

КонецПроцедуры

#КонецОбласти
