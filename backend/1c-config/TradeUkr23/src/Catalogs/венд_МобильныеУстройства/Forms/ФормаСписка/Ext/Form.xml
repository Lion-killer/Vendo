	<Attributes>
		<Attribute name="Список" id="21">
			<Type>
				<v8:Type>cfg:DynamicList</v8:Type>
			</Type>
			<MainAttribute>true</MainAttribute>
			<Settings xsi:type="DynamicList">
				<ManualQuery>true</ManualQuery>
				<DynamicDataRead>true</DynamicDataRead>
				<QueryText>ВЫБРАТЬ
	Устройства.Ссылка КАК Ссылка,
	Устройства.ПометкаУдаления КАК ПометкаУдаления,
	Устройства.Наименование КАК Наименование,
	Устройства.ИдентификаторУстройства КАК ИдентификаторУстройства,
	Устройства.Менеджер КАК Менеджер,
	Устройства.Заблокировано КАК Заблокировано,
	Телеметрия.ПоследняяАктивность КАК Активность,
	Телеметрия.Версия КАК Версия,
	Телеметрия.Модель КАК Модель,
	Телеметрия.ПоследняяСинхронизация КАК Синхронизация,
	Телеметрия.Очередь КАК Очередь,
	Телеметрия.Ошибки КАК Ошибки,
	Телеметрия.СетевыеТаймауты КАК Таймауты,
	ЛОЖЬ КАК ЗапросЛога
ИЗ
	Справочник.венд_МобильныеУстройства КАК Устройства
		ЛЕВОЕ СОЕДИНЕНИЕ РегистрСведений.венд_ТелеметрияУстройств.СрезПоследних КАК Телеметрия
		ПО Телеметрия.Устройство = Устройства.Ссылка</QueryText>
				<MainTable>Catalog.венд_МобильныеУстройства</MainTable>
			</Settings>
		</Attribute>
		<Attribute name="СлужебныйПользовательОтсутствует" id="57">
			<Type>
				<v8:Type>xs:boolean</v8:Type>
			</Type>
		</Attribute>
	</Attributes>
