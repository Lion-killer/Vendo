#Область ОбработчикиКомандФормы

// Редагування адреси мобільного сервісу (константа венд_АдресМобильногоСервиса) прямо зі
// списку пристроїв — щоб не шукати константу в меню. Простий діалог введення рядка з
// підказкою формату; зберігаємо без окремої форми.
&НаКлиенте
Процедура НастроитьURLСервиса(Команда)

	Подсказка = НСтр("uk='Адреса сервісу. Формат: http(s)://<сервер>/<база>/hs/vendo';
		|ru='Адрес сервиса. Формат: http(s)://<сервер>/<база>/hs/vendo';
		|en='Service URL. Format: http(s)://<server>/<base>/hs/vendo'");
	Оповещение = Новый ОписаниеОповещения("НастроитьURLСервисаЗавершение", ЭтаФорма);
	ПоказатьВводСтроки(Оповещение, ПрочитатьАдресСервиса(), Подсказка, 1000, Ложь);

КонецПроцедуры

// Очищення історії телеметрії (#42): видаляє записи регістра венд_ТелеметрияУстройств,
// старші за 30 днів, ЗБЕРІГАЮЧИ останній запис кожного пристрою (щоб зріз останніх у
// списку не спорожнів для неактивних пристроїв).
&НаКлиенте
Процедура ОчиститьТелеметрию(Команда)

	Вопрос = НСтр("uk='Видалити записи телеметрії, старші за 30 днів (крім останнього запису кожного пристрою)?';
		|ru='Удалить записи телеметрии старше 30 дней (кроме последней записи каждого устройства)?';
		|en='Delete telemetry records older than 30 days (keeping the latest record of each device)?'");
	Оповещение = Новый ОписаниеОповещения("ОчиститьТелеметриюЗавершение", ЭтаФорма);
	ПоказатьВопрос(Оповещение, Вопрос, РежимДиалогаВопрос.ДаНет);

КонецПроцедуры

// Журнал телеметрії (#42): список записів регістра з відбором за поточним пристроєм
// (без вибору — весь журнал). Відкриття запису показує збережений лог.
&НаКлиенте
Процедура ОткрытьТелеметрию(Команда)

	ПараметрыФормы = Новый Структура;
	ТекущиеДанные = Элементы.Список.ТекущиеДанные;

	Если ТекущиеДанные <> Неопределено Тогда

		Отбор = Новый Структура("Устройство", ТекущиеДанные.Ссылка);
		ПараметрыФормы.Вставить("Отбор", Отбор);

	КонецЕсли;

	ОткрытьФорму("РегистрСведений.венд_ТелеметрияУстройств.ФормаСписка", ПараметрыФормы, ЭтаФорма);

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Продовження діалогу введення адреси (ПоказатьВводСтроки) — викликається платформою.
//
// Параметры:
//  Значение - Строка, Неопределено - введена адреса або Неопределено при скасуванні.
//  ДополнительныеПараметры - Произвольный - не використовуються.
&НаКлиенте
Процедура НастроитьURLСервисаЗавершение(Значение, ДополнительныеПараметры) Экспорт

	Если Значение = Неопределено Тогда

		Возврат; // користувач скасував

	КонецЕсли;

	ЗаписатьАдресСервиса(СокрЛП(Значение));
	ПоказатьПредупреждение(, НСтр("uk='Адресу сервісу збережено';
		|ru='Адрес сервиса сохранён';
		|en='Service URL saved'"));

КонецПроцедуры

&НаСервереБезКонтекста
Функция ПрочитатьАдресСервиса()

	Возврат Константы.венд_АдресМобильногоСервиса.Получить();

КонецФункции

&НаСервереБезКонтекста
Процедура ЗаписатьАдресСервиса(Значение)

	Константы.венд_АдресМобильногоСервиса.Установить(Значение);

КонецПроцедуры

// Продовження діалогу підтвердження очищення телеметрії — викликається платформою.
//
// Параметры:
//  Результат - КодВозвратаДиалога - відповідь користувача;
//  ДополнительныеПараметры - Произвольный - не використовуються.
&НаКлиенте
Процедура ОчиститьТелеметриюЗавершение(Результат, ДополнительныеПараметры) Экспорт

	Если Результат <> КодВозвратаДиалога.Да Тогда

		Возврат;

	КонецЕсли;

	Удалено = ОчиститьТелеметриюНаСервере();
	Шаблон = НСтр("uk='Видалено записів: %1'; ru='Удалено записей: %1'; en='Records deleted: %1'");
	ПоказатьПредупреждение(, СтрЗаменить(Шаблон, "%1", Строка(Удалено)));

КонецПроцедуры

&НаСервереБезКонтекста
Функция ОчиститьТелеметриюНаСервере()

	УстановитьПривилегированныйРежим(Истина);

	// Записи старші за 30 днів, окрім останнього запису кожного пристрою.
	Запрос = Новый Запрос(
	"ВЫБРАТЬ
	|	Т.Устройство КАК Устройство,
	|	Т.Период КАК Период
	|ИЗ
	|	РегистрСведений.венд_ТелеметрияУстройств КАК Т
	|		ВНУТРЕННЕЕ СОЕДИНЕНИЕ (ВЫБРАТЬ
	|			Т2.Устройство КАК Устройство,
	|			МАКСИМУМ(Т2.Период) КАК МаксПериод
	|		ИЗ
	|			РегистрСведений.венд_ТелеметрияУстройств КАК Т2
	|		СГРУППИРОВАТЬ ПО
	|			Т2.Устройство) КАК Макс
	|		ПО Т.Устройство = Макс.Устройство
	|ГДЕ
	|	Т.Период < &Граница
	|	И Т.Период < Макс.МаксПериод");
	Запрос.УстановитьПараметр("Граница", ТекущаяДата() - 30 * 86400);

	Удалено = 0;
	Выборка = Запрос.Выполнить().Выбрать();
	Пока Выборка.Следующий() Цикл

		Набор = РегистрыСведений.венд_ТелеметрияУстройств.СоздатьНаборЗаписей();
		Набор.Отбор.Устройство.Установить(Выборка.Устройство);
		Набор.Отбор.Период.Установить(Выборка.Период);
		Набор.Записать(Истина); // порожній набір із відбором = видалення запису
		Удалено = Удалено + 1;

	КонецЦикла;

	Возврат Удалено;

КонецФункции

#КонецОбласти
