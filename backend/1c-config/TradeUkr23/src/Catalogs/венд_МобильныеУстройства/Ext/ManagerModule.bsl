#Область ПрограммныйИнтерфейс

// Рантайм-стан пристроїв у ХранилищеОбщихНастроек під фіксованим користувачем "vendo"
// (спільний неймспейс, а не налаштування поточного користувача). Мета: HTTP-сервіс НЕ пише
// в елемент довідника — токен, код прив'язки, прапорець логу й URL сервісу живуть у сховищі,
// а елемент лишається чистою конфігурацією, яку редагує тільки оператор.
//
// Усі функції — у привілейованому режимі: і сервіс (сесія "vendo"), і форми оператора
// (сесія іншого користувача) читають/пишуть той самий неймспейс "vendo".

// URL мобільного сервісу (спільний для всіх пристроїв). "" якщо не задано.
Функция АдресСервиса() Экспорт

	Возврат СтрокаНастройки("венд_Сервис", "URL");

КонецФункции

Процедура УстановитьАдресСервиса(Значение) Экспорт

	Сохранить("венд_Сервис", "URL", СокрЛП(Строка(Значение)));

КонецПроцедуры

// Числові параметри сервісу (#52) — у тому ж сховищі, редагуються командою
// «Налаштування сервісу» зі списку пристроїв. 0/не задано → умолчання.

// Зберігання історії телеметрії, днів (очищення старих записів).
Функция ХранениеТелеметрииДней() Экспорт

	Возврат ЧислоНастройки("ХранениеТелеметрииДней", 30);

КонецФункции

Процедура УстановитьХранениеТелеметрииДней(Значение) Экспорт

	Сохранить("венд_Сервис", "ХранениеТелеметрииДней", Значение);

КонецПроцедуры

// Глибина історії замовлень за умовчанням, днів (значення в картці пристрою перекриває).
Функция ГлубинаИсторииДней() Экспорт

	Возврат ЧислоНастройки("ГлубинаИсторииДней", 30);

КонецФункции

Процедура УстановитьГлубинуИсторииДней(Значение) Экспорт

	Сохранить("венд_Сервис", "ГлубинаИсторииДней", Значение);

КонецПроцедуры

// Тротлінг оновлення активності пасивної телеметрії, секунд.
Функция ТротлингАктивностиСек() Экспорт

	Возврат ЧислоНастройки("ТротлингАктивностиСек", 300);

КонецФункции

Процедура УстановитьТротлингАктивностиСек(Значение) Экспорт

	Сохранить("венд_Сервис", "ТротлингАктивностиСек", Значение);

КонецПроцедуры

// Інтервали фонових циклів додатка (#68), секунди — віддаються в GET /health (intervals).
// Фронт власних умолчань НЕ має: без значення цикл не запускається. Тому, на відміну від
// решти числових параметрів, явний 0 тут не «умолчання», а «цикл вимкнено».

// Фонова синхронізація даних (перечитування каталогу/клієнтів/замовлень).
Функция ИнтервалСинхронизацииСек() Экспорт

	Возврат ИнтервалНастройки("ИнтервалСинхронизацииСек", 300);

КонецФункции

Процедура УстановитьИнтервалСинхронизацииСек(Значение) Экспорт

	Сохранить("венд_Сервис", "ИнтервалСинхронизацииСек", Значение);

КонецПроцедуры

// Пінг HEAD /health (онлайн-індикатор додатка).
Функция ИнтервалПингаСек() Экспорт

	Возврат ИнтервалНастройки("ИнтервалПингаСек", 15);

КонецФункции

Процедура УстановитьИнтервалПингаСек(Значение) Экспорт

	Сохранить("венд_Сервис", "ИнтервалПингаСек", Значение);

КонецПроцедуры

// Періодична телеметрія (#42).
Функция ИнтервалТелеметрииСек() Экспорт

	Возврат ИнтервалНастройки("ИнтервалТелеметрииСек", 900);

КонецФункции

Процедура УстановитьИнтервалТелеметрииСек(Значение) Экспорт

	Сохранить("венд_Сервис", "ИнтервалТелеметрииСек", Значение);

КонецПроцедуры

// Момент останньої автоматичної чистки історії телеметрії (#53). Порожня дата,
// якщо чистка ще не виконувалась.
Функция ПоследняяОчисткаТелеметрии() Экспорт

	Значение = Загрузить("венд_Сервис", "ПоследняяОчисткаТелеметрии");
	Возврат ?(ТипЗнч(Значение) = Тип("Дата"), Значение, '00010101');

КонецФункции

Процедура УстановитьПоследнююОчисткуТелеметрии(Момент) Экспорт

	Сохранить("венд_Сервис", "ПоследняяОчисткаТелеметрии", Момент);

КонецПроцедуры

// SHA-256(токен) у base64. "" якщо пристрій ще не спарено.
Функция ХешТокена(ИдУстройства) Экспорт

	Возврат СтрокаНастройки("венд_ТокенУстройства", Строка(ИдУстройства));

КонецФункции

Процедура УстановитьХешТокена(ИдУстройства, Хеш) Экспорт

	Сохранить("венд_ТокенУстройства", Строка(ИдУстройства), СокрЛП(Строка(Хеш)));

КонецПроцедуры

// Одноразовий код прив'язки пристрою. "" якщо не задано/уже використано.
Функция КодПривязки(ИдУстройства) Экспорт

	Возврат СтрокаНастройки("венд_КодПривязки", Строка(ИдУстройства));

КонецФункции

Процедура УстановитьКодПривязки(ИдУстройства, Код) Экспорт

	Сохранить("венд_КодПривязки", Строка(ИдУстройства), СокрЛП(Строка(Код)));

КонецПроцедуры

// Чи запросив оператор повний лог із пристрою.
Функция ЗапрошенЛог(ИдУстройства) Экспорт

	Возврат Загрузить("венд_ЗапроситьЛог", Строка(ИдУстройства)) = Истина;

КонецФункции

Процедура УстановитьЗапросЛога(ИдУстройства, Значение) Экспорт

	Сохранить("венд_ЗапроситьЛог", Строка(ИдУстройства), Значение = Истина);

КонецПроцедуры

// Літерали режимів обробки замовлення (#65) — ОДНЕ джерело для форми й HTTP-сервісу
// (без розсипаних рядків): "create" — лише створити, "post" — створити й провести,
// "post_sale" — ще й створити непроведену РТУ на підставі замовлення.
Функция РежимыОбработкиЗаказа() Экспорт

	Возврат Новый ФиксированнаяСтруктура("Создать, Провести, Реализация",
		"create", "post", "post_sale");

КонецФункции

// Режим обробки синхронізованого замовлення для пристрою (#65). Зберігається per-device
// у сховищі (як ЗапрошенЛог), не в реквізиті довідника. Невідоме/порожнє → "create".
Функция РежимОбработкиЗаказа(ИдУстройства) Экспорт

	Значение = Загрузить("венд_РежимЗаказа", Строка(ИдУстройства));
	Режимы = РежимыОбработкиЗаказа();
	Если Значение = Режимы.Провести Или Значение = Режимы.Реализация Тогда

		Возврат Значение;

	КонецЕсли;

	Возврат Режимы.Создать;

КонецФункции

Процедура УстановитьРежимОбработкиЗаказа(ИдУстройства, Значение) Экспорт

	Сохранить("венд_РежимЗаказа", Строка(ИдУстройства), СокрЛП(Строка(Значение)));

КонецПроцедуры

// Прибрати весь рантайм-стан пристрою зі сховища (напр. при видаленні картки).
Процедура ОчиститьСостояние(ИдУстройства) Экспорт

	Ключ = Строка(ИдУстройства);
	Сохранить("венд_ТокенУстройства", Ключ, "");
	Сохранить("венд_КодПривязки", Ключ, "");
	Сохранить("венд_ЗапроситьЛог", Ключ, Ложь);
	Сохранить("венд_РежимЗаказа", Ключ, "");

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Спільний неймспейс сховища — усі налаштування зберігаються "від імені" цього користувача,
// незалежно від того, хто фактично в сесії.
Функция ПользовательНастроек()

	Возврат "vendo";

КонецФункции

Функция Загрузить(КлючОбъекта, КлючНастроек)

	УстановитьПривилегированныйРежим(Истина);
	Возврат ХранилищеОбщихНастроек.Загрузить(КлючОбъекта, КлючНастроек, , ПользовательНастроек());

КонецФункции

Процедура Сохранить(КлючОбъекта, КлючНастроек, Значение)

	УстановитьПривилегированныйРежим(Истина);
	ХранилищеОбщихНастроек.Сохранить(КлючОбъекта, КлючНастроек, Значение, , ПользовательНастроек());

КонецПроцедуры

// Числове налаштування сервісу (об'єкт "венд_Сервис"): додатне число зі сховища,
// інакше (не задано, не число, 0) — умолчання.
Функция ЧислоНастройки(КлючНастроек, Умолчание)

	Значение = Загрузить("венд_Сервис", КлючНастроек);
	Если ТипЗнч(Значение) = Тип("Число") И Значение > 0 Тогда

		Возврат Значение;

	КонецЕсли;

	Возврат Умолчание;

КонецФункции

// Як ЧислоНастройки, але явний 0 повертається як є — «цикл вимкнено» (#68).
// Умолчання — лише поки значення жодного разу не зберігали.
Функция ИнтервалНастройки(КлючНастроек, Умолчание)

	Значение = Загрузить("венд_Сервис", КлючНастроек);
	Если ТипЗнч(Значение) = Тип("Число") И Значение >= 0 Тогда

		Возврат Значение;

	КонецЕсли;

	Возврат Умолчание;

КонецФункции

// Значення сховища як обрізаний рядок; відсутнє (Неопределено) → "".
Функция СтрокаНастройки(КлючОбъекта, КлючНастроек)

	Значение = Загрузить(КлючОбъекта, КлючНастроек);
	Возврат ?(Значение = Неопределено, "", СокрЛП(Строка(Значение)));

КонецФункции

#КонецОбласти
