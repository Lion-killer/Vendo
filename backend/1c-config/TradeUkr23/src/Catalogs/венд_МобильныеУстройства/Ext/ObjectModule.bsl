#Область ОбработчикиСобытий

// Новий пристрій: ідентифікатор = GUID його посилання (за ним 1С знаходить пристрій,
// він же кодується в QR як deviceId). Заповнюємо вже при створенні, щоб показати у формі.
// Код прив'язки й хеш токена — не тут, а у ХранилищеОбщихНастроек (форма/сервіс), щоб API
// не писав в елемент довідника (див. модуль менеджера).
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, ТекстЗаполнения, СтандартнаяОбработка)

	ЗаполнитьИдентификаторУстройства();

КонецПроцедуры

// Копія — це інший пристрій: скидаємо ідентифікатор, щоб не дублювати deviceId джерела.
// Код прив'язки/токен джерела в сховищі прив'язані до його ідентифікатора — копія з новим
// ідентифікатором їх не успадкує (форма згенерує свій код прив'язки при збереженні).
Процедура ПриКопировании(ОбъектКопирования)

	ИдентификаторУстройства = "";
	ЗаполнитьИдентификаторУстройства();

КонецПроцедуры

// Підстраховка для програмного створення: якщо ідентифікатор досі порожній — присвоюємо.
Процедура ПередЗаписью(Отказ)

	ЗаполнитьИдентификаторУстройства();

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Процедура ЗаполнитьИдентификаторУстройства()

	ПустойГУИД = "00000000-0000-0000-0000-000000000000";
	Если ЗначениеЗаполнено(ИдентификаторУстройства) И ИдентификаторУстройства <> ПустойГУИД Тогда

		Возврат;

	КонецЕсли;

	Если ЭтоНовый() Тогда

		// Явно генеруємо GUID і фіксуємо його як посилання нового елемента (як у HTTP-сервісі).
		// ПолучитьСсылкуНового() у цій платформі повертав порожній GUID, тому робимо детерміновано.
		НовыйИД = Новый УникальныйИдентификатор();
		УстановитьСсылкуНового(Справочники.венд_МобильныеУстройства.ПолучитьСсылку(НовыйИД));
		ИдентификаторУстройства = Строка(НовыйИД);

	Иначе

		ИдентификаторУстройства = Строка(Ссылка.УникальныйИдентификатор());

	КонецЕсли;

КонецПроцедуры

#КонецОбласти
