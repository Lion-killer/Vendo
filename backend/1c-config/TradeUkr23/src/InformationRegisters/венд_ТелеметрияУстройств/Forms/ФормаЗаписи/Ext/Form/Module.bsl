#Область ОбработчикиСобытийФормы

// Розпаковує лог зі сховища значення (стиснений плоский текст журналу додатка, #42)
// у реквізит форми для перегляду і готує адресу тимчасового сховища для збереження у файл.
&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)

	МенеджерЗаписи = РеквизитФормыВЗначение("Запись");
	Хранилище = МенеджерЗаписи.Лог;

	Если ТипЗнч(Хранилище) = Тип("ХранилищеЗначения") Тогда

		Значение = Хранилище.Получить();
		Если ТипЗнч(Значение) = Тип("Строка") Тогда

			ТекстЛога = Значение;

		КонецЕсли;

	КонецЕсли;

	Если ПустаяСтрока(ТекстЛога) Тогда

		ТекстЛога = НСтр("uk='(лог із цим записом не передавався)';
			|ru='(лог с этой записью не передавался)';
			|en='(no log was sent with this record)'");

	Иначе

		АдресЛога = ПоместитьВоВременноеХранилище(
			ПолучитьДвоичныеДанныеИзСтроки(ТекстЛога), УникальныйИдентификатор);

	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

// Зберегти переглянутий лог у текстовий файл (діалог збереження платформи).
&НаКлиенте
Процедура СохранитьВФайл(Команда)

	Если ПустаяСтрока(АдресЛога) Тогда

		ПоказатьПредупреждение(, НСтр("uk='Лог із цим записом не передавався';
			|ru='Лог с этой записью не передавался';
			|en='No log was sent with this record'"));
		Возврат;

	КонецЕсли;

	ИмяФайла = "vendo-log-" + Формат(Запись.Период, "ДФ=yyyy-MM-dd_HH-mm-ss") + ".log";
	ПолучитьФайл(АдресЛога, ИмяФайла, Истина);

КонецПроцедуры

#КонецОбласти
