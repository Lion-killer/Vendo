// HTTP-сервіс "венд_МобильноеПриложение"
// REST API мобільного застосунку торгпреда (Vendo). Контракт сумісний із
// фронтендом: GET /products|categories|customers, GET/POST /orders,
// PUT/DELETE /orders/{num}, POST /auth.
//
// Усі дані фільтруються за МОБІЛЬНИМ ПРИСТРОЄМ
// (Справочник.венд_МобильныеУстройства). Ідентифікатор пристрою передається
// в заголовку "X-Device-Id" або в параметрі запиту ?device=<GUID>.
// Пристрій задає: склад (залишки), тип цін, менеджера, перелік контрагентів і товарів.
//
// УВАГА: створення ЗаказПокупателя використовує реквізити, специфічні для
// "Управління торгівлею для України". Поля, позначені // TODO, треба вивірити
// на бойовій базі (організація за умовчанням, договір взаєморозрахунків, валюта).
//
// Статусна модель: "Нове" — лише локальне (невідправлене) на клієнті, у 1С не існує;
// непроведений документ у базі → "Відправлено"; проведений → "Проведено"; з помітками
// на видалення → "Видалено". Проведення залежить від статусу в тілі запиту (див.
// ЗаписатьЗаказ/НужноПровести). Якщо проведення не проходить на бойовій (контроль
// залишків, незаповнені обов'язкові поля) — POST/PUT повертає 400 з описом помилки.

#Область ОбработчикиМетодов

// POST /auth — { deviceId, pairingCode } -> обмін одноразового коду прив'язки
// на bearer-токен. Токен у базі не зберігається — лише його SHA-256; повертається
// клієнту один раз. Код прив'язки після успіху гаситься (повторне використання
// неможливе). Заблокований пристрій не авторизується.
Функция AuthPost(Запрос) Экспорт
	Попытка
	Тело = ПрочитатьТелоJSON(Запрос);
	ИдУстройства = "";
	КодПривязки = "";
	Если ТипЗнч(Тело) = Тип("Соответствие") Тогда
		Если Тело.Получить("deviceId") <> Неопределено Тогда
			ИдУстройства = СокрЛП(Строка(Тело.Получить("deviceId")));
		КонецЕсли;
		Если Тело.Получить("pairingCode") <> Неопределено Тогда
			КодПривязки = СокрЛП(Строка(Тело.Получить("pairingCode")));
		КонецЕсли;
	КонецЕсли;
	Если ПустаяСтрока(ИдУстройства) Тогда
		ИдУстройства = ИдентификаторУстройстваИзЗапроса(Запрос);
	КонецЕсли;

	Устройство = НайтиУстройство(ИдУстройства);
	Если Устройство = Неопределено Тогда
		Сообщ = НСтр("uk='Пристрій не зареєстровано'; ru='Устройство не зарегистрировано'; en='Device is not registered'",
			КодЯзыкаЗапроса(Запрос));
		Возврат ОтветJSON(Новый Структура("success, message", Ложь, Сообщ), 401);
	КонецЕсли;
	Если Устройство.Заблокировано Тогда
		Сообщ = НСтр("uk='Пристрій заблоковано'; ru='Устройство заблокировано'; en='Device is blocked'",
			КодЯзыкаЗапроса(Запрос));
		Возврат ОтветJSON(Новый Структура("success, message", Ложь, Сообщ), 401);
	КонецЕсли;
	// Код прив'язки має бути заданий у картці пристрою і збігатися (звіряємо без врахування регістру).
	Если ПустаяСтрока(КодПривязки) Или ПустаяСтрока(Устройство.КодПривязки)
		Или НРег(КодПривязки) <> НРег(СокрЛП(Устройство.КодПривязки)) Тогда
		Сообщ = НСтр("uk='Невірний або використаний код прив''язки'; ru='Неверный или использованный код привязки'; en='Invalid or already used pairing code'",
			КодЯзыкаЗапроса(Запрос));
		Возврат ОтветJSON(Новый Структура("success, message", Ложь, Сообщ), 401);
	КонецЕсли;

	Токен = НовыйТокен();
	ОбъектУстройства = Устройство.ПолучитьОбъект();
	ОбъектУстройства.ХешТокена = ХешТокенаСтрокой(Токен);
	ОбъектУстройства.КодПривязки = ""; // одноразовий — гасимо після видачі токена
	ОбъектУстройства.Записать();

	Пользователь = Новый Структура("name, role", Строка(Устройство.Менеджер), "sales_rep");
	Возврат ОтветJSON(Новый Структура("success, user, token", Истина, Пользователь, Токен));
	Исключение
		Возврат ОтветИсключение(Запрос, ОписаниеОшибки());
	КонецПопытки;
КонецФункции

// GET /products — номенклатура пристрою з ціною (за типом цін) і залишком (за складом).
