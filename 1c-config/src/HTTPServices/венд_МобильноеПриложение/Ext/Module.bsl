// GET /products/{id}/image — основне зображення номенклатури (бінарно).
// Джерело: Справочник.Номенклатура.ОсновноеИзображение (тип
// Справочник.ХранилищеДополнительнойИнформации), байти — у реквізиті "Хранилище"
// (ХранилищеЗначения). Content-Type визначається за розширенням ИмяФайла. 404 — якщо
// товару/зображення немає. Захищено так само, як решта (X-Device-Id + bearer-токен),
// тож застосунок тягне картинку через fetch із заголовками, а не голим <img src>.
Функция ProductImageGet(Запрос) Экспорт
	Попытка
	Устройство = ОпределитьУстройство(Запрос);
	Если Устройство = Неопределено Тогда Возврат ОтветНеАвторизован(Запрос); КонецЕсли;

	СсылкаТовара = СсылкаНоменклатуры(Запрос.ПараметрыURL.Получить("id"));
	Если СсылкаТовара = Неопределено Тогда Возврат ОтветБезТела(404); КонецЕсли;

	ЭлементХранилища = СсылкаТовара.ОсновноеИзображение;
	Если НЕ ЗначениеЗаполнено(ЭлементХранилища) Тогда Возврат ОтветБезТела(404); КонецЕсли;

	// У цій УТ байти зберігаються у реквізиті "Хранилище" (ХранилищеЗначения) як об'єкт
	// Картинка (звірено на бойовій). Дістаємо ДвоичныеДанные й MIME беремо з формату
	// картинки (ИмяФайла порожнє). Підстраховуємось і на випадок прямих ДвоичныхДанных.
	Содержимое = ЭлементХранилища.Хранилище;
	Если ТипЗнч(Содержимое) = Тип("ХранилищеЗначения") Тогда
		Содержимое = Содержимое.Получить();
	КонецЕсли;

	ТипКонтента = "application/octet-stream";
	ДвоичныеДанные = Неопределено;
	Если ТипЗнч(Содержимое) = Тип("Картинка") Тогда
		ДвоичныеДанные = Содержимое.ПолучитьДвоичныеДанные();
		ТипКонтента = MIMEПоФорматуКартинки(Содержимое.Формат());
	ИначеЕсли ТипЗнч(Содержимое) = Тип("ДвоичныеДанные") Тогда
		ДвоичныеДанные = Содержимое;
		ТипКонтента = MIMEПоИмениФайла(Строка(ЭлементХранилища.ИмяФайла));
	КонецЕсли;
	Если ДвоичныеДанные = Неопределено Тогда Возврат ОтветБезТела(404); КонецЕсли;

	Ответ = Новый HTTPСервисОтвет(200);
	Ответ.УстановитьТелоИзДвоичныхДанных(ДвоичныеДанные);
	Ответ.Заголовки.Вставить("Content-Type", ТипКонтента);
	Ответ.Заголовки.Вставить("Access-Control-Allow-Origin", "*");
	Ответ.Заголовки.Вставить("Cache-Control", "public, max-age=86400");
	Возврат Ответ;
	Исключение
		Возврат ОтветИсключение(Запрос, ОписаниеОшибки());
	КонецПопытки;
КонецФункции

