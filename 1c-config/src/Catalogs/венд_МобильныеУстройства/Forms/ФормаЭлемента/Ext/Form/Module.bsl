#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	СформироватьQR();
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	// Код прив'язки змінюється тільки при записі — перемальовуємо QR за збереженими даними.
	СформироватьQR();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура СгенерироватьКодПривязки(Команда)
	// Новий одноразовий код прив'язки. Анулює раніше виданий токен (переприв'язка):
	// очищаємо хеш, щоб старий токен перестав діяти. Потрібно зберегти запис.
	Объект.КодПривязки = СтрЗаменить(Строка(Новый УникальныйИдентификатор()), "-", "");
	Объект.ХешТокена = "";
	Модифицированность = Истина;
	ПоказатьПредупреждение(, НСтр("uk='Згенеровано новий код прив''язки. Збережіть пристрій — і QR оновиться.'"));
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура СформироватьQR()
	// Без GUID кодувати нічого
	Если Не ЗначениеЗаполнено(Объект.ИдентификаторУстройства) Тогда
		АдресКартинкиQR = "";
		Возврат;
	КонецЕсли;
	// Вміст QR — формат, що очікує мобільний сканер (scanner.js -> parseQr):
	// JSON { deviceId, apiUrl, code }. code — одноразовий код прив'язки (обмінюється на токен у /auth).
	АдресСервиса = Константы.венд_АдресМобильногоСервиса.Получить();
	Содержимое = "{""deviceId"":""" + Объект.ИдентификаторУстройства + """,""apiUrl"":""" + АдресСервиса
		+ """,""code"":""" + СокрЛП(Объект.КодПривязки) + """}";
	ДвоичныеДанные = УправлениеПечатью.ДанныеQRКода(Содержимое, 1, 200);
	АдресКартинкиQR = ПоместитьВоВременноеХранилище(ДвоичныеДанные, УникальныйИдентификаторФормы);
КонецПроцедуры

#КонецОбласти
