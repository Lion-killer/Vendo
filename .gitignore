# Dependencies
node_modules/

# Build output
frontend/dist/
frontend/build_err.txt

# Локальні env (адреса бекенду тощо); приклад — frontend/.env.example
frontend/.env
frontend/.env.local

# SQLite database (runtime data; re-seeds from db.json)
backend/data/*.db
backend/data/*.db-shm
backend/data/*.db-wal

# Capacitor / Android build artifacts
frontend/android/.gradle/
frontend/android/**/build/
frontend/android/local.properties
frontend/android/.idea/
frontend/android/app/src/main/assets/public/

# 1C metadata export (reference only, large; not part of the app)
TradeUkr/

# 1C: згенерований файл налаштувань порівняння/об'єднання
1c-config/MergeSettings*.xml

# Design-tool handoff: зберігаємо .jsx-джерела, ігноруємо важкий бандл і артефакти
design/**/*standalone*.html
design/**/.thumbnail
design/**/.design-canvas.state.json
design/*.zip

# Кошторис і інструмент його формування — поза git
/estimate/

# Згенеровані QR-коди авторизації (містять локальні адреси/IP)
/qr-auth/

# Office lock-файли
~$*
*.tmp

# Logs
*.log
npm-debug.log*

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Робочі вихідники іконки (генеруються у android/res через @capacitor/assets)
frontend/assets/
