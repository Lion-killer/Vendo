# Dependencies
node_modules/

# Build output
frontend/dist/
frontend/build_err.txt

# Згенерована копія довідки (канон — docs/user-guide; копіюється скриптом перед збіркою)
frontend/src/help/
frontend/public/help-images/

# Локальні env (адреса бекенду тощо); приклад — frontend/.env.example
frontend/.env
frontend/.env.local

# Capacitor / Android build artifacts
frontend/android/.gradle/
frontend/android/**/build/
frontend/android/local.properties
frontend/android/.idea/
frontend/android/app/src/main/assets/public/

# Ключ підпису release-APK (створює scripts/release.mjs; втрата = оновлення не встановляться)
frontend/android/*.keystore
frontend/android/keystore.properties
frontend/releases/

# Транзитні файли релізу (чернетка чейнджлогу на погодження, нотатки для gh)
frontend/.changelog-draft.md
frontend/.release-notes.md

# 1C metadata export (reference only, large; not part of the app)
TradeUkr/

# 1C: згенерований файл налаштувань порівняння/об'єднання
backend/1c-config/**/MergeSettings*.xml

# 1C: файли публікації веб-сервера містять рядок з'єднання з базою і ПАРОЛЬ відкритим
# текстом (Usr=…;Pwd=…) — реальні .vrd не комітити ніколи. Виняток — демонстраційний
# взірець у TradeUkr23/iis/ (плейсхолдер замість пароля, узагальнений шлях до бази).
*.vrd
!backend/1c-config/TradeUkr23/iis/default.vrd

# Design-tool handoff: зберігаємо .jsx-джерела, ігноруємо важкий бандл і артефакти
design/**/*standalone*.html
design/**/.thumbnail
design/**/.design-canvas.state.json
design/*.zip

# Кошторис і інструмент його формування — поза git
/estimate/

# Локальні робочі матеріали (чужі обробки/дампи для звірки) — ніколи не комітити
/Temp/

# Згенеровані QR-коди авторизації (містять локальні адреси/IP)
/qr-auth/

# Office lock-файли
~$*
*.tmp

# Logs
*.log
npm-debug.log*

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Робочі вихідники іконки (генеруються у android/res через @capacitor/assets)
frontend/assets/
